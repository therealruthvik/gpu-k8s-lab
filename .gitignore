# Terraform state — contains real resource IDs and may contain secrets
terraform.tfstate
terraform.tfstate.backup
.terraform.tfstate.lock.info

# tfvars contains your IP, AWS profile, key names — don't commit
terraform.tfvars

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# SSH keys (if accidentally placed here)
*.pem
*.key

